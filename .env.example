# ⚠️  THIS FILE IS A TEMPLATE. DO NOT PUT REAL TOKENS HERE.
#
# The sotda library itself is I/O-free and NEVER reads these values.
# This file exists only to document what environment variables YOUR
# private SNS generator project should define when it imports sotda.
#
# Copy this to `.env` (gitignored) in YOUR generator project, not here.

# Threads Graph API access token (obtained via Meta Developer Console OAuth)
THREADS_ACCESS_TOKEN=your-long-lived-token-here

# Threads user ID of the account you're analyzing
THREADS_USER_ID=1234567890

# Optional: rolling window for author baseline (days)
SOTDA_BASELINE_WINDOW_DAYS=30

# Optional: minimum hours to wait before scoring a post (let views accumulate)
SOTDA_MIN_POST_AGE_HOURS=6
